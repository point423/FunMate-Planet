# Runtime
NODE_ENV=production
PORT=8080
APP_VERSION=0.0.1-SNAPSHOT

# Database
# Cloud platforms may provide MYSQLHOST/MYSQLPORT/MYSQLDATABASE/MYSQLUSER/MYSQLPASSWORD automatically.
# DATABASE_URL takes priority when set and must be a JDBC URL.
DATABASE_URL=jdbc:mysql://localhost:3306/funmate_planet?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
DB_HOST=localhost
DB_PORT=3306
DB_NAME=funmate_planet
DB_USERNAME=root
DB_PASSWORD=dev123

# Redis
# REDIS_URL takes priority when set.
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Security
JWT_SECRET=replace_with_a_32_char_or_longer_secret
JWT_EXPIRE_SECONDS=86400
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Monitoring
LOG_LEVEL=INFO

# Uploads
UPLOAD_DIR=uploads/
UPLOAD_PUBLIC_URL=http://localhost:8080/static/

# Frontend build
VITE_API_BASE_URL=/api

# AI configuration
# 默认接 MiniMax 云端 API（OpenAI 兼容）
# 去 https://platform.minimax.io 申请 API Key
# 备选 base URL:
#   - https://api.minimax.chat/v1     (国际)
#   - https://api.minimaxi.com/v1     (中国区)
#   - https://api.openai.com/v1       (OpenAI)
#   - https://api.deepseek.com/v1     (DeepSeek)
#   - http://ollama:11434/v1          (本地 Ollama,需 0.1.14+)
# 备选 model:
#   - MiniMax-M2.7                    (MiniMax 旗舰)
#   - MiniMax-M2.5                    (MiniMax 性价比)
#   - MiniMax-M2-her                  (MiniMax 角色扮演)
#   - abab6.5s-chat                   (MiniMax 老版)
#   - deepseek-chat                   (DeepSeek)
#   - gpt-4o-mini                     (OpenAI)
#   - qwen2.5:1.5b                    (本地 Ollama)
AI_BASE_URL=https://api.minimax.chat/v1
AI_MODEL=MiniMax-M2.7
AI_API_KEY=your_minimax_api_key_here